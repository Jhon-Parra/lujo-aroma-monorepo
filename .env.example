## Lujo & Aroma (local/dev)
## Copy to `.env` and fill values.

# Backend
HOST=127.0.0.1
FRONTEND_URL=http://localhost:4200
# Produccion / multiples origins (separados por coma)
# Ej: FRONTEND_URLS=https://lujo_aroma.com,https://www.lujo_aroma.com
FRONTEND_URLS=
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
DATABASE_SSL=true
JWT_SECRET=change_me
REFRESH_SECRET=change_me

# Supabase Auth
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Opcional: verifica JWT localmente sin llamar a Supabase
SUPABASE_JWT_SECRET=

# Wompi (Bancolombia)
# WOMPI_ENV=sandbox | production
WOMPI_ENV=sandbox
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_INTEGRITY_SECRET=

# Clave maestra para cifrar secretos en ConfiguracionGlobal (base64, 32 bytes)
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SETTINGS_ENCRYPTION_KEY=
GOOGLE_CLIENT_ID=
GEMINI_API_KEY=

# Instagram (para mostrar publicaciones en inicio)
# Requiere un access token valido de Instagram Basic Display.
INSTAGRAM_ACCESS_TOKEN=

# Email (notificaciones de pedidos)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Lujo & Aroma <no-reply@lujo_aroma.com>"
EMAIL_REPLY_TO=
EMAIL_BCC_ORDERS=
